---
import '../styles/global.css';

// Pre-generate 80 image definitions (only strings, very fast)
const allImages = Array.from({ length: 80 }).map((_, i) => ({
  id: i,
  url: `https://loremflickr.com/800/${Math.floor(Math.random() * 500 + 600)}/landscape,nature?lock=${i + 200}`,
  alt: 'Landscape photography'
}));

const initialBatch = allImages.slice(0, 8);
const remainingImages = allImages.slice(8);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Masonry Pro | Performance</title>
	</head>
	<body>
    <main class="container">
      <div id="grid" class="masonry-grid">
        {initialBatch.map((img, i) => (
          <div class="masonry-item" style={`animation-delay: ${i * 0.1}s`}>
            <img src={img.url} alt={img.alt} />
          </div>
        ))}
      </div>
      <div id="sentinel" style="height: 20px; margin-top: 20px;"></div>
    </main>

    <script define:vars={{ remainingImages }}>
      let pool = [...remainingImages];
      const grid = document.getElementById('grid');
      const sentinel = document.getElementById('sentinel');

      const loadBatch = () => {
        if (pool.length === 0) return;
        
        const nextBatch = pool.splice(0, 8); // Tomamos de 8 en 8
        nextBatch.forEach((img, i) => {
          const div = document.createElement('div');
          div.className = 'masonry-item';
          div.style.animationDelay = `${i * 0.05}s`;
          div.innerHTML = `<img src="${img.url}" alt="${img.alt}" loading="lazy" />`;
          grid.appendChild(div);
        });
      };

      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          loadBatch();
        }
      }, { rootMargin: '200px' });

      observer.observe(sentinel);
    </script>
	</body>
</html>
