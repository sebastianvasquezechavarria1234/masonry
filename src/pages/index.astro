---
import '../styles/global.css';

const items = [
  {
    title: "Minimalist Space",
    desc: "Modern architectural exploration",
    image: "/architecture_1.png",
    category: "Architecture"
  },
  {
    title: "Tropical Mist",
    desc: "Morning in the deep jungle",
    image: "/nature_1.png",
    category: "Nature"
  },
  {
    title: "Cyber City",
    desc: "Neon dreams and rain",
    image: "https://images.unsplash.com/photo-1514565131-fce0801e5785?auto=format&fit=crop&q=80&w=800",
    category: "Cyberpunk"
  },
  {
    title: "Abstract Flow",
    desc: "Fluid dynamics in gold",
    image: "https://images.unsplash.com/photo-1541701494587-cb58502866ab?auto=format&fit=crop&q=80&w=800",
    category: "Abstract"
  },
  {
    title: "Mountain Silence",
    desc: "Snowy peaks at dusk",
    image: "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&q=80&w=800",
    category: "Nature"
  },
  {
    title: "Urban Geometry",
    desc: "Lines and perspectives",
    image: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=800",
    category: "Architecture"
  },
  {
    title: "Desert Solitude",
    desc: "Endless sands and heat",
    image: "https://images.unsplash.com/photo-1473580044384-7ba9967e16a0?auto=format&fit=crop&q=80&w=800",
    category: "Nature"
  },
  {
    title: "Vibrant Chaos",
    desc: "A splash of energy",
    image: "https://images.unsplash.com/photo-1549490349-8643362247b5?auto=format&fit=crop&q=80&w=800",
    category: "Abstract"
  }
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Masonry Premium | Visual Showcase</title>
	</head>
	<body>
    <nav class="glass-nav">
      <a href="#" class="nav-link active">Explore</a>
      <a href="#" class="nav-link">Categories</a>
      <a href="#" class="nav-link">About</a>
      <a href="#" class="nav-link">Contact</a>
    </nav>

    <main class="container">
      <header class="header">
        <h1 class="gradient-text">Masonry</h1>
        <p class="item-desc">A premium visual showcase for modern aesthetics.</p>
      </header>

      <div class="masonry-grid">
        {items.map((item) => (
          <div class="masonry-item">
            <img src={item.image} alt={item.title} loading="lazy" />
            <div class="item-overlay">
              <span class="item-desc" style="color: var(--accent-primary); font-weight: 600; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em;">{item.category}</span>
              <h3 class="item-title">{item.title}</h3>
              <p class="item-desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </main>

    <footer style="padding: 4rem 0; text-align: center; border-top: 1px solid var(--card-border);">
      <p class="item-desc">&copy; 2026 Masonry Studio. All rights reserved.</p>
    </footer>
	</body>
</html>
